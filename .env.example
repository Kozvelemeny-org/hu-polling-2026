# Cloudflare Web Analytics (optional; leave empty to disable)
PUBLIC_CF_BEACON_TOKEN=

# Data base URL for CSV/JSON data (e.g. https://tiles.tiborcz.club/data).
# Static base URL for the embeds (e.g. https://tiles.tiborcz.club/).
# Local: set in .env. Vercel: set in Project Settings > Environment Variables (available at build).
PUBLIC_DATA_BASE_URL=
PUBLIC_STATIC_BASE_URL=

# Public URL for the embeds (e.g. https://2026.kozvelemeny.org/abra/t-main/embed).
PUBLIC_EMBED_BASE_URL=